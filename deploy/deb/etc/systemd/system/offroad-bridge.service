[Unit]
Description=Offroad Traversability Bridge
After=network.target

[Service]
Type=simple
User=offroad
WorkingDirectory=/usr/local/lib/offroad
Environment=OFFROAD_CONFIG=/etc/offroad/offroad.yaml
ExecStart=/usr/local/lib/offroad/venv/bin/python3 \
          /usr/local/lib/offroad/bridge/bridge.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
